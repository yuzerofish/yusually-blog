# This _headers file works for Netlify and Cloudflare. For other providers, you may want to configure these headers yourself, depending on your setup.

# TanStack Start generated assets (hash-based filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/manifest.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=3600

/favicon.ico
  Cache-Control: public, max-age=604800

/*.png
  Cache-Control: public, max-age=604800

/*.svg
  Cache-Control: public, max-age=604800

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "blog-starter",
  "main": "@tanstack/react-start/server-entry",
  "compatibility_date": "2026-05-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "vars": {
    "VITE_BASE_URL": "https://blog-starter.01mvp.com",
    "CMS_PUBLIC_SITE_URL": "https://blog-starter.01mvp.com",
    "CMS_EMAIL_SENDING_ENABLED": "false",
    "CMS_TURNSTILE_SECRET_KEY": "",
    "VITE_TURNSTILE_SITE_KEY": "",
  },
  "d1_databases": [
    {
      "binding": "CMS_DB",
      "database_name": "blog-starter-cms",
      "database_id": "b267c97c-72a5-45a1-9f5a-cfd0b8e8067c",
      "migrations_dir": "../../packages/db/migrations",
    },
  ],
  "r2_buckets": [
    {
      "binding": "CMS_ASSETS",
      "bucket_name": "blog-starter-assets",
    },
    {
      "binding": "CMS_BACKUPS",
      "bucket_name": "blog-starter-backups",
    },
  ],
  "kv_namespaces": [
    {
      "binding": "CMS_CACHE",
      "id": "c1150cc286374ba9919f48f48a985f36",
    },
  ],
}

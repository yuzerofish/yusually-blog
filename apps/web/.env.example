VITE_BASE_URL=http://localhost:3000
CMS_PUBLIC_SITE_URL=http://localhost:3000
CMS_BACKUP_RETENTION_DAYS=30
CMS_EMAIL_SENDING_ENABLED=false
CMS_EMAIL_FROM=
CMS_EMAIL_TO=
CMS_PASSWORD_RESET_TTL_MINUTES=30
CMS_TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
BETTER_AUTH_SECRET=

# Cloudflare bindings are provided by Wrangler in preview/production:
# CMS_DB, CMS_ASSETS, CMS_BACKUPS, CMS_CACHE

# Generate with: pnpm auth:secret

# Comment login OAuth, optional but recommended.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub OAuth callback URLs:
# Local: http://localhost:3000/api/auth/callback/github
# Production: https://your-domain.com/api/auth/callback/github
